# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (client-safe; formerly "anon" key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (server-only; formerly "service_role" key) — NEVER commit or expose to the browser
SUPABASE_SECRET_KEY=

# Postgres direct connection string (used by `supabase db push` and scripts)
# Supabase Dashboard → Project Settings → Database → Connection string → URI (transaction pooler)
# e.g. postgresql://postgres.xxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ── App ─────────────────────────────────────────────────────────────────────
# The URL where this app is served. Used for magic-link redirect.
# Local dev: http://localhost:3000
# Production: https://your-domain.com (or your Vercel URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret for the Vercel Cron endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Anthropic (Phase 2 onward — leave blank for Phase 1) ────────────────────
ANTHROPIC_API_KEY=
